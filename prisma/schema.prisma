generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  password String
  name     String
  role     String  @default("admin")
  photoUrl String?
}

model Employee {
  id         String     @id @default(cuid())
  name       String
  email      String?
  costCenter String
  photoUrl   String?
  jobTitle   String?
  startDate  DateTime?
  active     Boolean    @default(true)
  createdAt  DateTime   @default(now())
  kpiEntries   KpiEntry[]
  closedMonths ClosedMonth[]
}

model KpiEntry {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime
  periodType String   @default("week")
  costCenter String
  comment    String?

  // Vertrieb
  kundenbesuche          Int @default(0)
  telefonate             Int @default(0)
  auftraegeAkquiriert    Int @default(0)
  auftraegeAbgeschlossen Int @default(0)

  // Profile / Recruiting
  profile                Int?
  vorstellungsgespraeche Int?
  deals                  Int?

  // Personal
  eintritte Int?
  austritte Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, date])
}

model ClosedMonth {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  year       Int
  month      Int      // 0-11
  closedAt   DateTime @default(now())

  @@unique([employeeId, year, month])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String
  changes    String
  createdAt  DateTime @default(now())
}
